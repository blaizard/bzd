# Tweak the output
build --show_progress_rate_limit=60
build --noshow_loading_progress
build --show_timestamps

# Exclude long and eternal tests.
test --test_timeout_filters=-long,-eternal

# Use remote execution.
build --config=remote
test --config=remote

# Enable disk cache
common --disk_cache=/cache/bazel/disk_cache
common --repository_cache=/cache/bazel/repository_cache
common --experimental_disk_cache_gc_max_size=10G
