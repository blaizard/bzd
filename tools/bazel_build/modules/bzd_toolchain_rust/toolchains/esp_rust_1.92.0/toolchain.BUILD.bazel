"""Toolchain."""

load("@rules_rust//rust:toolchain.bzl", "rust_stdlib_filegroup")

package(default_visibility = ["//visibility:public"])

alias(
    name = "rustc",
    actual = "bin/rustc",
)

alias(
    name = "rustdoc",
    actual = "bin/rustdoc",
)

filegroup(
    name = "rustc_lib",
    srcs = glob(
        [
            "bin/*.so",
            "lib/*.so*",
            "lib/rustlib/x86_64-unknown-linux-gnu/codegen-backends/*.so",
            "lib/rustlib/x86_64-unknown-linux-gnu/lib/*.so*",
            "lib/rustlib/x86_64-unknown-linux-gnu/lib/*.rmeta",
        ],
        allow_empty = True,
    ),
)

rust_stdlib_filegroup(
    name = "stdlib_exec",
    srcs = glob(
        [
            "stdlib_exec/lib/rustlib/x86_64-unknown-linux-gnu/lib/*.rlib",
            "stdlib_exec/lib/rustlib/x86_64-unknown-linux-gnu/lib/*.so*",
            "stdlib_exec/lib/rustlib/x86_64-unknown-linux-gnu/lib/*.a",
            "stdlib_exec/lib/rustlib/x86_64-unknown-linux-gnu/lib/self-contained/**",
        ],
        # Some patterns (e.g. `lib/*.a`) don't match anything, see https://github.com/bazelbuild/rules_rust/pull/245
        allow_empty = True,
    ),
)
