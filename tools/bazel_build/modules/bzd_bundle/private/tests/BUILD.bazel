load("@bzd_lib//:defs.bzl", "bzd_diff_test", "bzd_executable_test")
load("@rules_shell//shell:sh_binary.bzl", "sh_binary")
load("//private:bundle_binary.bzl", "bzd_bundle_binary")
load("//private:bundle_tar.bzl", "bzd_bundle_tar")

sh_binary(
    name = "dummy",
    srcs = [
        "dummy.sh",
    ],
    data = [
        "dummy.txt",
    ],
)

bzd_bundle_tar(
    name = "empty_tar",
    compression = None,
    output = "empty_tar.tar",
)

bzd_bundle_tar(
    name = "dummy_tar",
    srcs = [
        ":dummy",
    ],
    include_runfiles = True,
    output = "dummy_tar.tar",
)

bzd_diff_test(
    name = "reproducible_empty_tar",
    file1 = ":empty_tar.tar",
    file2 = "expected_empty.tar",
)

# Test that the same binary with different compression algorithms produces reproducible output.
_binaries_to_compression = {
    "binary": None,
    "binary_bz2": "bz2",
    "binary_gz": "gz",
    "binary_xz": "xz",
}

[bzd_bundle_binary(
    name = name,
    compression = compression,
    executable = ":dummy",
) for name, compression in _binaries_to_compression.items()]

[bzd_executable_test(
    name = "test_{}".format(name),
    executable = name,
    expected_output = "from dummy.sh\nfrom dummy.txt",
    expected_returncode = "0",
) for name, _ in _binaries_to_compression.items()]
