{
    "nodes.dashboards": [
        {
            "inputs": {
                "/data/cpu/{name}": {}
            },
            "max": 1,
            "min": 0,
            "title": "CPU {name}",
            "type": "linear",
            "unit": "percent"
        },
        {
            "inputs": {
                "/data/gpu/{name}": {}
            },
            "max": 1,
            "min": 0,
            "title": "GPU {name}",
            "type": "linear",
            "unit": "percent"
        },
        {
            "inputs": {
                "/data/cpu_frequency/{name}": {}
            },
            "min": 0,
            "title": "CPU Frequency {name}",
            "type": "linear",
            "unit": "frequency"
        },
        {
            "inputs": {
                "/data/disk/{name}/total": {},
                "/data/disk/{name}/used": {}
            },
            "min": 0,
            "title": "Disk {name}",
            "type": "linear",
            "unit": "bytes"
        },
        {
            "inputs": {
                "/data/memory/{name}/total": {},
                "/data/memory/{name}/used": {}
            },
            "min": 0,
            "title": "Memory {name}",
            "type": "linear",
            "unit": "bytes"
        },
        {
            "groupBy": [
                "name"
            ],
            "inputs": {
                "/data/io/{name}/usage": {}
            },
            "max": 1,
            "min": 0,
            "title": "IO usage",
            "type": "linear",
            "unit": "percent"
        },
        {
            "groupBy": [
                "name"
            ],
            "inputs": {
                "/data/io/{name}/in": {}
            },
            "min": 0,
            "title": "IO write",
            "type": "linear",
            "unit": "bytes/s"
        },
        {
            "groupBy": [
                "name"
            ],
            "inputs": {
                "/data/io/{name}/out": {}
            },
            "min": 0,
            "title": "IO read",
            "type": "linear",
            "unit": "bytes/s"
        },
        {
            "groupBy": [
                "name"
            ],
            "inputs": {
                "/data/network/{name}/in": {}
            },
            "min": 0,
            "title": "Network recv",
            "type": "linear",
            "unit": "bytes/s"
        },
        {
            "groupBy": [
                "name"
            ],
            "inputs": {
                "/data/network/{name}/out": {}
            },
            "min": 0,
            "title": "Network send",
            "type": "linear",
            "unit": "bytes/s"
        },
        {
            "inputs": {
                "/data/battery/{name}": {}
            },
            "max": 1,
            "min": 0,
            "title": "Battery {name}",
            "type": "linear",
            "unit": "percent"
        },
        {
            "inputs": {
                "/data/temperature/{name}": {}
            },
            "min": 0,
            "title": "Temperature {name}",
            "type": "linear",
            "unit": "celsius"
        }
    ],
    "nodes.handlers": {
        "/data/log": {
            "history": 100,
            "toString": "[{level}] [{name}] [{source}] {message}"
        }
    },
    "nodes.mcp": {
        "/@mcp/compute": {
            "tools": {
                "get": {
                    "doc": "Get current CPU, memory, network, etc. statistics for a specific node."
                },
                "list_nodes": {
                    "doc": "Get a list of all available nodes."
                }
            }
        }
    },
    "nodes.schema": {
        "/data/battery": {
            "additionalProperties": {
                "items": {
                    "maximum": 1,
                    "minimum": 0,
                    "type": "number"
                },
                "type": "array"
            },
            "description": "Battery charge level per battery unit, values are in the range [0, 1].",
            "type": "object"
        },
        "/data/cpu": {
            "additionalProperties": {
                "items": {
                    "maximum": 1,
                    "minimum": 0,
                    "type": "number"
                },
                "type": "array"
            },
            "description": "CPU utilization per core, values are in the range [0, 1].",
            "type": "object"
        },
        "/data/cpu_frequency": {
            "additionalProperties": {
                "items": {
                    "minimum": 0,
                    "type": "number"
                },
                "type": "array"
            },
            "description": "CPU frequency per core in Hz.",
            "type": "object"
        },
        "/data/disk": {
            "additionalProperties": {
                "properties": {
                    "total": {
                        "minimum": 0,
                        "type": "number"
                    },
                    "used": {
                        "minimum": 0,
                        "type": "number"
                    }
                },
                "type": "object"
            },
            "description": "Disk usage per mount point, containing total and used space.",
            "type": "object"
        },
        "/data/gpu": {
            "additionalProperties": {
                "items": {
                    "maximum": 1,
                    "minimum": 0,
                    "type": "number"
                },
                "type": "array"
            },
            "description": "GPU utilization per device, values are in the range [0, 1].",
            "type": "object"
        },
        "/data/io": {
            "additionalProperties": {
                "properties": {
                    "in": {
                        "minimum": 0,
                        "type": "number"
                    },
                    "out": {
                        "minimum": 0,
                        "type": "number"
                    },
                    "usage": {
                        "maximum": 1,
                        "minimum": 0,
                        "type": "number"
                    }
                },
                "type": "object"
            },
            "description": "Disk I/O statistics per device, including inbound, outbound throughput and usage ratio.",
            "type": "object"
        },
        "/data/memory": {
            "additionalProperties": {
                "properties": {
                    "total": {
                        "minimum": 0,
                        "type": "number"
                    },
                    "used": {
                        "minimum": 0,
                        "type": "number"
                    }
                },
                "type": "object"
            },
            "description": "Memory usage per zone, containing total and used memory.",
            "type": "object"
        },
        "/data/network": {
            "additionalProperties": {
                "properties": {
                    "in": {
                        "minimum": 0,
                        "type": "number"
                    },
                    "out": {
                        "minimum": 0,
                        "type": "number"
                    }
                },
                "type": "object"
            },
            "description": "Network traffic per interface, including inbound and outbound throughput.",
            "type": "object"
        },
        "/data/temperature": {
            "additionalProperties": {
                "items": {
                    "type": "number"
                },
                "type": "array"
            },
            "description": "Temperature readings per sensor in degrees Celsius.",
            "type": "object"
        },
        "/data/uptime": {
            "description": "System uptime in seconds.",
            "minimum": 0,
            "type": "number"
        }
    }
}